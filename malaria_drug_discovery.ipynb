## Step 3: Target Identification

Search for Plasmodium falciparum targets in ChEMBL. We'll look for a well-known malaria drug target.

```python
# Initialize ChEMBL clients
target = new_client.target
activity = new_client.activity

# Search for Plasmodium falciparum targets
# Popular target: Dihydrofolate reductase (DHFR) - antimalarial drug target
# Also: Cytochrome b1, ATPase, etc.

# Search for target organism: Plasmodium falciparum
pf_targets = target.filter(
    target_organism__icontains='Plasmodium falciparum'
).only(['target_chembl_id', 'target_name', 'organism', 'target_type'])

# Convert to DataFrame
pf_targets_df = pd.DataFrame(pf_targets)
print(f"Found {len(pf_targets_df)} Plasmodium falciparum targets\n")
print(pf_targets_df.head(10))
```

```python
# Select a well-characterized target - Dihydrofolate reductase (DHFR)
# This is a classic antimalarial target

# Filter for DHFR specifically
dhfr_targets = target.filter(
    target_organism__icontains='Plasmodium falciparum',
    target_name__icontains='dihydrofolate'
).only(['target_chembl_id', 'target_name', 'organism'])

dhfr_df = pd.DataFrame(dhfr_targets)
print("Dihydrofolate Reductase targets in P. falciparum:")
print(dhfr_df)
```

```python
# Select the first DHFR target
# ChEMBL ID for P. falciparum DHFR
target_chembl_id = 'CHEMBL3961323'  # Update based on results
target_name = 'Dihydrofolate reductase (Plasmodium falciparum)'

# Alternative: If not found, use a broader search
if not dhfr_df.empty:
    target_chembl_id = dhfr_df.iloc[0]['target_chembl_id']
    target_name = dhfr_df.iloc[0]['target_name']

print(f"Selected Target: {target_name}")
print(f"ChEMBL ID: {target_chembl_id}")
```

---

## Step 4: Bioactivity Data Retrieval

Fetch compounds with bioactivity data (IC50, Ki, EC50) against our target.

```python
# Fetch bioactivity data for the target
# Filter by activity type: IC50, Ki, EC50 (meaningful activity values)
bioactivity = activity.filter(
    target_chembl_id=target_chembl_id,
    activity_type__in=['IC50', 'Ki', 'EC50'],
    relation='=',
    confidence_score__gte=9  # High confidence (direct target interaction)
).only([
    'molecule_chembl_id', 'activity_id', 'activity_type', 
    'relation', 'value', 'units', 'target_chembl_id',
    'molecule_pref_name', 'canonical_smiles'
])

bioactivity_df = pd.DataFrame(bioactivity)
print(f"Initial bioactivity records: {len(bioactivity_df)}")
print(bioactivity_df.head())
```

```python
# Check available activity types
print("Activity types distribution:")
print(bioactivity_df['activity_type'].value_counts())
print(f"\nUnits: {bioactivity_df['units'].unique()}")
```

```python
# Filter for standard units (nM - nanomolar is most common)
bioactivity_df = bioactivity_df[bioactivity_df['units'] == 'nM']
print(f"After filtering to nM: {len(bioactivity_df)} records")
```

---

## Step 5: Data Cleaning and Preprocessing

```python
# Data cleaning steps
# 1. Remove duplicates (same compound)
bioactivity_df = bioactivity_df.drop_duplicates(subset=['molecule_chembl_id'])

# 2. Handle missing values - remove rows with missing SMILES or activity values
bioactivity_df = bioactivity_df.dropna(subset=['canonical_smiles', 'value'])

# 3. Convert activity values to numeric
bioactivity_df['value'] = pd.to_numeric(bioactivity_df['value'], errors='coerce')
bioactivity_df = bioactivity_df.dropna(subset=['value'])

# 4. Remove invalid SMILES
def is_valid_smiles(smiles):
    try:
        mol = Chem.MolFromSmiles(smiles)
        return mol is not None
    except:
        return False

bioactivity_df = bioactivity_df[bioactivity_df['canonical_smiles'].apply(is_valid_smiles)]

print(f"After cleaning: {len(bioactivity_df)} unique compounds")
print(f"\nDataFrame shape: {bioactivity_df.shape}")
print(bioactivity_df.head())
```

```python
# For analysis, let's focus on IC50 values (most common)
# Lower IC50 = more potent compound
bioactivity_ic50 = bioactivity_df[bioactivity_df['activity_type'] == 'IC50'].copy()
print(f"Compounds with IC50 data: {len(bioactivity_ic50)}")
```

---

## Step 6: Molecular Descriptor Calculation using RDKit

Calculate key molecular descriptors for drug-likeness:
- Molecular Weight (MW)
- LogP (lipophilicity)
- Hydrogen bond donors/acceptors
- TPSA (Topological Polar Surface Area)

```python
# Function to calculate molecular descriptors
def calculate_descriptors(smiles):
    """Calculate molecular descriptors for a given SMILES"""
    try:
        mol = Chem.MolFromSmiles(smiles)
        if mol is None:
            return None
        
        descriptors = {
            'Molecular_Weight': Descriptors.MolWt(mol),
            'LogP': Descriptors.MolLogP(mol),
            'HBD': Lipinski.NumHDonors(mol),  # Hydrogen Bond Donors
            'HBA': Lipinski.NumHAcceptors(mol),  # Hydrogen Bond Acceptors
            'TPSA': Descriptors.TPSA(mol),  # Topological Polar Surface Area
            'Num_Rotatable_Bonds': Lipinski.NumRotatableBonds(mol),
            'Num_Aromatic_Rings': Lipinski.NumAromaticRings(mol),
            'Num_Heavy_Atoms': Descriptors.HeavyAtomCount(mol)
        }
        return descriptors
    except:
        return None

# Apply to all compounds
print("Calculating molecular descriptors...")
descriptors_list = []

for idx, row in bioactivity_df.iterrows():
    desc = calculate_descriptors(row['canonical_smiles'])
    if desc:
        desc['molecule_chembl_id'] = row['molecule_chembl_id']
        desc['activity_value'] = row['value']
        desc['activity_type'] = row['activity_type']
        desc['units'] = row['units']
        desc['molecule_name'] = row.get('molecule_pref_name', 'Unknown')
        descriptors_list.append(desc)

# Create DataFrame with descriptors
descriptors_df = pd.DataFrame(descriptors_list)
print(f"Calculated descriptors for {len(descriptors_df)} compounds")
```

```python
# Display the descriptors
print("\nMolecular Descriptors DataFrame:")
print(descriptors_df.head(10))
print(f"\nShape: {descriptors_df.shape}")
```

