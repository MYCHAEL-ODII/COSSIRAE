## Step 8: Visualization

```python
# Create visualizations
fig, axes = plt.subplots(2, 3, figsize=(15, 10))

# 1. Activity value distribution (log scale)
ax1 = axes[0, 0]
bioactivity_ic50['log_IC50'] = np.log10(bioactivity_ic50['value'])
sns.histplot(bioactivity_ic50['log_IC50'], bins=30, ax=ax1, color='steelblue')
ax1.set_xlabel('log10(IC50, nM)')
ax1.set_title('Distribution of IC50 Values')

# 2. Molecular Weight vs LogP (colored by drug-likeness)
ax2 = axes[0, 1]
colors = descriptors_df['Drug_like'].map({True: 'green', False: 'red'})
ax2.scatter(descriptors_df['Molecular_Weight'], descriptors_df['LogP'], 
            c=colors, alpha=0.6, s=30)
ax2.axvline(x=500, color='black', linestyle='--', label='MW=500')
ax2.axhline(y=5, color='black', linestyle=':', label='LogP=5')
ax2.set_xlabel('Molecular Weight (Da)')
ax2.set_ylabel('LogP')
ax2.set_title('MW vs LogP (Green=Drug-like)')
ax2.legend()

# 3. TPSA distribution
ax3 = axes[0, 2]
sns.histplot(descriptors_df['TPSA'], bins=30, ax=ax3, color='coral')
ax3.axvline(x=140, color='black', linestyle='--', label='TPSA=140')
ax3.set_xlabel('TPSA (Å²)')
ax3.set_title('Topological Polar Surface Area')
ax3.legend()

# 4. HBD vs HBA
ax4 = axes[1, 0]
ax4.scatter(descriptors_df['HBD'], descriptors_df['HBA'], 
           c=descriptors_df['Drug_like'].map({True: 'green', False: 'red'}), 
           alpha=0.6, s=30)
ax4.axvline(x=5, color='black', linestyle='--')
ax4.axhline(y=10, color='black', linestyle=':')
ax4.set_xlabel('Hydrogen Bond Donors')
ax4.set_ylabel('Hydrogen Bond Acceptors')
ax4.set_title('HBD vs HBA')

# 5. Activity vs MW (for lead compounds)
ax5 = axes[1, 1]
if len(lead_compounds) > 0:
    ax5.scatter(lead_compounds['Molecular_Weight'], 
               lead_compounds['activity_value'], 
               s=80, alpha=0.7, c='purple')
    ax5.set_xlabel('Molecular Weight (Da)')
    ax5.set_ylabel('IC50 (nM)')
    ax5.set_title('Lead Compounds: MW vs Potency')
else:
    ax5.text(0.5, 0.5, 'No lead compounds found', ha='center', va='center')

# 6. Potency categories pie chart
ax6 = axes[1, 2]
if 'IC50' in descriptors_df['activity_type'].values:
    potency_counts = ic50_df['Potency_Category'].value_counts()
    ax6.pie(potency_counts, labels=potency_counts.index, autopct='%1.1f%%', 
           colors=['green', 'orange', 'red'])
    ax6.set_title('Potency Distribution')

plt.tight_layout()
plt.savefig('drug_discovery_analysis.png', dpi=150, bbox_inches='tight')
plt.show()
print("\n✓ Visualization saved as 'drug_discovery_analysis.png'")
```

