## Step 7: Data Analysis and Lead Compound Identification

```python
# Summary statistics
print("="*60)
print("SUMMARY STATISTICS - Molecular Descriptors")
print("="*60)
print(descriptors_df[['Molecular_Weight', 'LogP', 'HBD', 'HBA', 'TPSA']].describe())
```

```python
# Drug-likeness criteria (Lipinski's Rule of Five)
# - MW <= 500 Da
# - LogP <= 5
# - HBD <= 5
# - HBA <= 10

descriptors_df['Drug_like'] = (
    (descriptors_df['Molecular_Weight'] <= 500) &
    (descriptors_df['LogP'] <= 5) &
    (descriptors_df['HBD'] <= 5) &
    (descriptors_df['HBA'] <= 10)
)

print(f"\nDrug-like compounds (Lipinski's Rule of Five): {descriptors_df['Drug_like'].sum()}")
print(f"Percentage: {100 * descriptors_df['Drug_like'].sum() / len(descriptors_df):.1f}%")
```

```python
# Identify LEAD COMPOUNDS
# Criteria: Potent (low IC50) AND drug-like

if 'IC50' in descriptors_df['activity_type'].values:
    ic50_df = descriptors_df[descriptors_df['activity_type'] == 'IC50'].copy()
    
    # Define potency thresholds (in nM)
    # < 100 nM = very potent
    # 100-1000 nM = potent
    # > 1000 nM = moderate
    
    ic50_df['Potency_Category'] = pd.cut(
        ic50_df['activity_value'],
        bins=[0, 100, 1000, float('inf')],
        labels=['Very Potent (<100nM)', 'Potent (100-1000nM)', 'Moderate (>1000nM)']
    )
    
    # Lead compounds: potent + drug-like
    lead_compounds = ic50_df[
        (ic50_df['activity_value'] < 1000) &  # Potent
        (ic50_df['Drug_like'] == True)  # Drug-like
    ].sort_values('activity_value')
    
    print("="*60)
    print("TOP LEAD COMPOUNDS (Potent + Drug-like)")
    print("="*60)
    print(lead_compounds[['molecule_name', 'activity_value', 'Molecular_Weight', 
                          'LogP', 'HBD', 'HBA', 'TPSA']].head(15))
```

